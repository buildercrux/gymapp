PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/gym-management
JWT_SECRET=change-this-secret
JWT_EXPIRES_IN=7d
# Comma-separated allowed frontend origins. Replace YOUR_LAN_IP with your PC's current address.
CLIENT_URLS=http://localhost:5173,http://127.0.0.1:5173,http://YOUR_LAN_IP:5173
DEMO_OTP_MODE=false
DEMO_OTP=123456
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com
SMTP_TLS_REJECT_UNAUTHORIZED=true
